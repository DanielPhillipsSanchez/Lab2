# =============================================================================
# EVOLV PERFORMANCE INTELLIGENCE - dbt Profile Configuration (Example)
# =============================================================================
# Copy this file to ~/.dbt/profiles.yml and update with your credentials
# =============================================================================

evolv_pi:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: <your_account>
      user: <your_username>
      password: <your_password>
      role: SYSADMIN
      database: COCO_SDLC_HOL
      warehouse: PERFORMANCE_INTELLIGENCE_WH
      schema: PUBLIC
      threads: 4
      client_session_keep_alive: False
      query_tag: dbt_evolv_pi
