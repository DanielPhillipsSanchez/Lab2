# Snowflake Connection Configuration
# Copy this file to .env.local and fill in SNOWFLAKE_ACCOUNT before running.
#
# This file is pre-configured to connect as the HOL service account
# (COCO_SDLC_HOL_SERVICE_USER) using the RSA key pair provisioned by
# packages/database/hol_setup.sql. No other changes are needed.

# --- Required: your Snowflake account identifier ----------------------------
# Find it in Snowsight: bottom-left corner -> account name, or Admin > Accounts.
# Format: <orgname>-<accountname>  (e.g., myorg-myaccount)
SNOWFLAKE_ACCOUNT=

# --- Service account (pre-configured -- do not change) ----------------------
SNOWFLAKE_USER=COCO_SDLC_HOL_SERVICE_USER
SNOWFLAKE_ROLE=ATTENDEE_ROLE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# --- RSA key-pair auth (pre-configured -- do not change) --------------------
